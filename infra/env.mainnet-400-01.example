# Example only. Copy privately on the trading host as .env.mainnet-400-01.
# Do not commit real keys, wallet addresses, tokens, or database passwords.

# ── Identity (must differ from pilot) ──────────────────────────────────────
LIVE_INSTANCE_ID=mainnet-400-01
PUBLIC_INSTANCE_SLUG=mainnet-400-01
EXCHANGE_ACCOUNT_ID=hl-mainnet-400-01
EXCHANGE_ACCOUNT_LABEL=Hyperliquid-Mainnet-400-01
PUBLIC_INSTANCE_DISPLAY_NAME=Mainnet 400-01
LIVE_INSTANCE_MODE=mainnet_pilot
LIVE_INSTANCE_STATUS=paused
PUBLIC_INSTANCE_STATUS=hidden

# ── PostgreSQL (shared DB with pilot) ──────────────────────────────────────
POSTGRES_DB=cta_forge_live
POSTGRES_USER=cta_forge_live
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://cta_forge_live:REPLACE_ME@postgres:5432/cta_forge_live
PERSISTENCE_BACKEND=postgres
ALLOW_POSTGRES_SOURCE_OF_TRUTH=true
LIVE_PERSISTENCE_SHADOW_FAILURE_POLICY=raise

# ── Hyperliquid account (separate wallet from pilot) ───────────────────────
HL_PRIVATE_KEY=
HL_ACCOUNT_ADDRESS=
HL_NETWORK=mainnet

# ── Live gates (flip on go-live day) ───────────────────────────────────────
DRY_RUN=true
STRATEGY_PROFILE=v16a-mainnet-pilot
ALLOW_LIVE=false
ALLOW_MAINNET_PILOT_UNCAPPED_ORDERS=false

# ── Strategy parameters (aligned with pilot) ──────────────────────────────
TARGET_SCALE=5.0
TARGET_GROSS_CAP=4.00
HL_LEVERAGE=5
V16A_MAX_STALENESS_HOURS=8
V16A_CORE_PHASE_HOURS=2
LIVE_SYMBOLS=BTC,ETH,SOL,BNB,XRP,DOGE,AVAX,LINK,ADA,DOT,ATOM,NEAR,APT,ARB,OP,SUI,INJ,TIA,SEI
MAX_ORDER_NOTIONAL=200
MIN_ORDER_NOTIONAL=10

# ── Account guards (scaled to 400 USDT; preflight-only checks) ────────────
# MIN_EQUITY: refuse to start if equity falls below this floor (catastrophe)
MIN_EQUITY=50
# MAX_EQUITY: refuse to start if equity exceeds this ceiling (wrong wallet)
MAX_EQUITY=800
# MIN_AVAILABLE_BALANCE: refuse to start if free balance below this
MIN_AVAILABLE_BALANCE=0

# ── Per-instance paths (must differ from pilot) ────────────────────────────
DATA_DIR=/app/data
STATE_FILE=/app/state/engine-state-mainnet-400-01.json
JOURNAL_DIR=/app/journal/mainnet-400-01

# ── Notifications (use separate chat/channel from pilot) ───────────────────
TG_BOT_TOKEN=
TG_CHAT_ID=
LARK_WEBHOOK_URL=
LARK_WEBHOOK_SECRET=

# ── Preflight requirements ─────────────────────────────────────────────────
REQUIRE_LIVE_INSTANCE_LOCK_AVAILABLE=true
REQUIRE_DB_ACCOUNT_ADDRESS_MATCH=true
